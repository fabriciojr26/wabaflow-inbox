# WabaFlow Inbox v6 - exemplo de ambiente (NUNCA commitar tokens reais)
NODE_ENV=development
PORT=8787

# Modos permitidos: simulated | cloud_ready | production_locked
WABAFLOW_MODE=simulated

# WhatsApp Cloud API (futuro; nesta fase não há envio real)
WHATSAPP_VERIFY_TOKEN=meu_token_de_verificacao_webhook
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0

# Telemetria opcional
LOG_LEVEL=info
