{
  "name": "wabaflow-inbox",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c green,cyan \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --host 0.0.0.0 --port 5173",
    "dev:api": "node --watch server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "reset": "node server/index.js --reset"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {}
}
